# =============================================================
# ReTo Pipeline - Variables de Entorno
# =============================================================
# Copiar este archivo a .env y rellenar con valores reales.
# NUNCA subir .env al repositorio.
# =============================================================

# --- PostgreSQL (Neon Cloud) ---
DB_HOST=ep-xxxxx.us-east-1.aws.neon.tech
DB_PORT=5432
DB_NAME=reto_db
DB_USER=neondb_owner
DB_PASSWORD=
DB_SSLMODE=require

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2

# --- YouTube Data API ---
YOUTUBE_API_KEY=

# --- Google Drive (Service Account) ---
GOOGLE_DRIVE_CREDENTIALS=config/service-account.json
GOOGLE_DRIVE_FOLDER_ID=

# --- Anonimización ---
RETO_SALT=

# --- Rutas del proyecto (solo necesarias en Docker) ---
# En local estas variables NO se definen; los scripts usan sus rutas por defecto.
# En Docker se definen apuntando a /app/...
#
# PROJECT_ROOT=/app
# DATA_RAW_DIR=/app/data/raw
# DATA_MASTER_DIR=/app/data/master
